pipeline {
    agent any

    parameters {
        choice(
            name: 'TARGET_ENV',
            choices: ['main', 'dev'],
            description: 'Choose which environment to deploy'
        )
    }

    stages {
        stage('Check images exists') {
            steps {
                script {
                    if (params.TARGET_ENV == 'main') {
                        sh 'docker image inspect nodemain:v1.0'
                    }
                    else if (params.TARGET_ENV == 'dev') {
                        sh 'docker image inspect nodedev:v1.0'
                    }
                }
            }
        }
    }
}
